{
  "name": "tiktok-tv-nextjs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "socket": "node server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run socket\"",
    "pm2:start": "pm2 start npm --name \"tiktok-nextjs\" -- run start && pm2 start node --name \"tiktok-socket\" -- server.js",
    "pm2:stop": "pm2 stop tiktok-nextjs tiktok-socket",
    "pm2:delete": "pm2 delete tiktok-nextjs tiktok-socket",
    "pm2:restart": "pm2 restart tiktok-nextjs tiktok-socket",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:save": "pm2 save",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "tiktok-live-connector": "^2.1.1-beta1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}